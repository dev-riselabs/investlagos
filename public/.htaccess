# ----------------------------------------------------------------------
# SPA routing — send every non-file/non-directory request to index.html
# so React Router (BrowserRouter) can resolve the URL on the client.
# ----------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Force HTTPS (optional — comment out if your host terminates TLS upstream)
    # RewriteCond %{HTTPS} !=on
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # If the request matches a real FILE on disk, serve it directly.
    # Note: we deliberately do NOT short-circuit on real directories,
    # because some asset folders (e.g. /governance, /speakers) share a
    # name with a React Router route. Letting those URLs fall through to
    # index.html lets React Router resolve them, while individual asset
    # requests like /governance/foo.png still match -f and are served.
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Otherwise, hand the request to index.html (SPA fallback).
    RewriteRule ^ index.html [L]
</IfModule>

# ----------------------------------------------------------------------
# Correct MIME types (some shared hosts mis-serve JS modules / fonts).
# ----------------------------------------------------------------------
<IfModule mod_mime.c>
    AddType application/javascript            .js .mjs
    AddType text/css                          .css
    AddType image/svg+xml                     .svg
    AddType application/font-woff             .woff
    AddType application/font-woff2            .woff2
    AddType application/vnd.ms-fontobject     .eot
    AddType font/ttf                          .ttf
    AddType font/otf                          .otf
</IfModule>

# ----------------------------------------------------------------------
# Gzip compression for text-based assets.
# ----------------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ----------------------------------------------------------------------
# Long-lived caching for hashed assets, no caching for index.html.
# ----------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On

    ExpiresByType text/html               "access plus 0 seconds"
    ExpiresByType text/css                "access plus 1 year"
    ExpiresByType application/javascript  "access plus 1 year"
    ExpiresByType image/png               "access plus 1 year"
    ExpiresByType image/jpeg              "access plus 1 year"
    ExpiresByType image/gif               "access plus 1 year"
    ExpiresByType image/svg+xml           "access plus 1 year"
    ExpiresByType image/webp              "access plus 1 year"
    ExpiresByType font/woff               "access plus 1 year"
    ExpiresByType font/woff2              "access plus 1 year"
    ExpiresByType font/ttf                "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    # Never cache the SPA entry point — users must always get the latest
    # hashed asset references after a deploy.
    <FilesMatch "^index\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>

    # Never cache the service-worker file either, otherwise old builds linger.
    <FilesMatch "^sw\.js$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>

    # CORS for self-hosted fonts (safe; assets are public).
    <FilesMatch "\.(ttf|otf|woff|woff2)$">
        Header set Access-Control-Allow-Origin "*"
    </FilesMatch>
</IfModule>

# ----------------------------------------------------------------------
# Hardening
# ----------------------------------------------------------------------
Options -Indexes

<FilesMatch "^\.(env|gitignore|htaccess)$">
    Require all denied
</FilesMatch>
